{
  "name": "galelugi-pecas",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:api": "python manage.py runserver",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev\"",
    "build": "npm run build --prefix frontend",
    "start": "npm run build && npm run start --prefix server",
    "install:all": "npm install --prefix frontend && npm install --prefix server"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
